# ----- zsh behavior -----
setopt PROMPT_SUBST
setopt APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS

HISTFILE="${ZDOTDIR:-$HOME}/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000

# ----- ls colors -----
if command ls --color=auto -d . >/dev/null 2>&1; then
  alias ls='ls --color=auto'
elif command ls -G -d . >/dev/null 2>&1; then
  export CLICOLOR=1
  alias ls='ls -G'
fi

# ----- prompt -----
autoload -Uz vcs_info add-zsh-hook

zstyle ':vcs_info:git:*' formats '%b '

_update_vcs_info() {
  vcs_info
}
add-zsh-hook precmd _update_vcs_info

PROMPT='%F{green}%*%f %F{blue}%~%f %F{red}${vcs_info_msg_0_}%f$ '

# ----- ctrl-arrow word movement -----
bindkey '^[[1;5D' backward-word
bindkey '^[[1;5C' forward-word

# ----- homebrew -----
if command -v brew >/dev/null 2>&1; then
  eval "$(brew shellenv)"
elif [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# ----- completions -----
if [[ -d "$HOME/.docker/completions" ]]; then
  fpath=("$HOME/.docker/completions" $fpath)
fi

autoload -Uz compinit && compinit -u

# ----- fzf -----
if command -v fzf >/dev/null 2>&1; then
  if fzf --zsh >/dev/null 2>&1; then
    # fzf's generated zsh integration may warn while restoring the read-only zle option.
    # Filter that known harmless warning while preserving any other stderr output.
    source <(fzf --zsh) 2> >(grep -v "can't change option: zle" >&2)
  else
    # Fallback for older distro-packaged fzf.
    [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]] && source /usr/share/doc/fzf/examples/key-bindings.zsh
    [[ -f /usr/share/doc/fzf/examples/completion.zsh ]] && source /usr/share/doc/fzf/examples/completion.zsh
  fi
fi

if command -v fd >/dev/null 2>&1; then
  export FZF_DEFAULT_COMMAND="fd --hidden --strip-cwd-prefix --exclude .git"
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_ALT_C_COMMAND="fd --type=d --hidden --strip-cwd-prefix --exclude .git"

  _fzf_compgen_path() {
    fd --hidden --exclude .git . "$1"
  }

  _fzf_compgen_dir() {
    fd --type=d --hidden --exclude .git . "$1"
  }
fi

if [[ -f "$HOME/.fzf-git.sh" ]]; then
  source "$HOME/.fzf-git.sh"
fi

if command -v bat >/dev/null 2>&1 && command -v eza >/dev/null 2>&1; then
  show_file_or_dir_preview='if [ -d {} ]; then eza --tree --color=always {} | head -200; else bat -n --color=always --line-range :500 {}; fi'

  export FZF_CTRL_T_OPTS="--preview '$show_file_or_dir_preview'"
  export FZF_ALT_C_OPTS="--preview 'eza --tree --color=always {} | head -200'"

  # Ctrl-R: syntax-highlighted preview of the selected history command ({2..} drops
  # the history index). Hidden by default; reveal/hide with Ctrl-/. Inherits BAT_THEME.
  export FZF_CTRL_R_OPTS="
    --preview 'echo {2..} | bat --color=always -pl bash'
    --preview-window up:3:hidden:wrap
    --bind 'ctrl-/:toggle-preview'"

  _fzf_comprun() {
    local command=$1
    shift

    case "$command" in
      cd)           fzf --preview 'eza --tree --color=always {} | head -200' "$@" ;;
      export|unset) fzf --preview "eval 'echo $'{}" "$@" ;;
      ssh)          fzf --preview 'command -v dig >/dev/null 2>&1 && dig {}' "$@" ;;
      *)            fzf --preview "bat -n --color=always --line-range :500 {}" "$@" ;;
    esac
  }
fi

# ----- unified theme system (Ghostty + fzf + bat + delta + nvim + herdr + hunk + lazygit) -----
# One source of truth: ~/.config/theme/state (+ macOS light/dark appearance).
# Sets FZF_DEFAULT_OPTS / BAT_THEME for this shell and defines the `theme` command.
# fzf palettes: ~/.config/fzf/themes/*.fzf   bat themes: ~/.config/bat/themes/*.tmTheme
[[ -r ~/.config/theme/init.zsh ]] && source ~/.config/theme/init.zsh

# ----- eza -----
if command -v eza >/dev/null 2>&1; then
  alias ll='eza --color=always --long --git --no-filesize --icons=auto --no-user'
  alias la='eza --color=always --long --all --git --no-filesize --icons=auto --no-user'
  alias lt='eza --tree --level=3 --color=always --icons=auto'
fi

# ----- zoxide -----
if command -v zoxide >/dev/null 2>&1 && [[ "${CLAUDECODE:-}" != "1" ]]; then
  eval "$(zoxide init zsh)"
fi

# ----- zsh-autosuggestions -----
if [[ -n "${HOMEBREW_PREFIX:-}" && -f "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]]; then
  source "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
elif [[ -f /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
  source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

