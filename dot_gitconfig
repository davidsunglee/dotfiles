[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true # use n and N to move between diff sections
	side-by-side = true

	# delta detects terminal colors automatically; set one of these to disable auto-detect
	# dark = true
	# light = true

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[delta "delta-dark"]
	dark = true
[delta "delta-light"]
	light = true
