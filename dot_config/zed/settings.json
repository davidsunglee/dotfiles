// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // >>> theme-controller: extensions installed on Zed launch (managed list) >>>
  "auto_install_extensions": {
    "catppuccin": true,
    "rose-pine-theme": true,
    "tokyo-night": true,
    "nord": true,
    "poimandres": true,
    "solarized": true,
    "dracula": true,
    "kanagawa-themes": true,
    "everforest": true
  },
  // <<< theme-controller <<<
  "project_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "pi-acp": {
      "type": "registry"
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "theme": { "mode": "dark", "light": "Nord", "dark": "Nord" },
  "icon_theme": "Warm Charmed Icons",

  "buffer_font_size": 15,
  "ui_font_size": 16,

  "base_keymap": "VSCode",
  "format_on_save": "off"
}
